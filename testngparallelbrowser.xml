<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="QKart Cross-Browser Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.mystore.listeners.TestListener"/>
    </listeners>
    
    <test name="Grid UI Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.mystore.tests.LoginTests" />
            <class name="com.mystore.tests.CartTests" />
            <class name="com.mystore.tests.CheckoutTests" />
        </classes>
    </test>

    <test name="Grid UI Tests - Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.mystore.tests.LoginTests" />
            <class name="com.mystore.tests.CartTests" />
            <class name="com.mystore.tests.CheckoutTests" />
        </classes>
    </test>
    
</suite>